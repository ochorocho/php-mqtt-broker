{
    "name": "php-mqtt/broker",
    "description": "A pure-PHP MQTT broker supporting MQTT 3.1.1 and 5.0",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "react/socket": "^1.15",
        "react/event-loop": "^1.5",
        "psr/log": "^3.0",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "PhpMqtt\\Broker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpMqtt\\Broker\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
